[user]
	name = {{ .name }}
	email = {{ .email }}

[core]
	autocrlf = input
	excludesfile = ~/.gitignore_global
	ignorecase = false
	editor = cursor --wait
	pager = delta

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	side-by-side = true
	line-numbers = true

[diff]
	tool = difftastic
	colorMoved = default

[difftool "difftastic"]
	cmd = difft "$LOCAL" "$REMOTE"

[difftool]
	prompt = false

[merge]
	tool = cursor
	conflictstyle = zdiff3

[mergetool "cursor"]
	cmd = cursor --wait $MERGED

[pull]
	ff = only

[fetch]
	prune = true

[gpg]
	format = ssh

[gpg "ssh"]
	program = "/Applications/1Password.app/Contents/MacOS/op-ssh-sign"

[commit]
	template = ~/.gitmessage
	gpgsign = true

[include]
	path = ~/.gitconfig.local
